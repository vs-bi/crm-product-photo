BaseURI_IS=https://twoja-domena.creatio.com/identity
BaseURI=https://twoja-domena.creatio.com
client_id=
client_secret=
grant_type=client_credentials

# Opcjonalnie: pobierz tylko wybrane kody (np. do testu)
# PRODUCT_CODES=70056

# Ścieżka zapisu JPG (w Dockerze: /app/product_images)
OUTPUT_DIR=/app/product_images
IMAGE_SERVER_PORT=8000

# Linki w Excelu — przez nginx na vs-web (port 8001 na hoście)
# Linki w Excelu (HTTP w sieci wewnętrznej). Po firmowym CA: https://vs-web/crm_product_images
PUBLIC_IMAGE_BASE_URL=http://vs-web/crm_product_images

# Ścieżka GUI Streamlit za reverse proxy
STREAMLIT_BASE_URL_PATH=product_photos
